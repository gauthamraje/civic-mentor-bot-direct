{
  "rewrites": [
    {
      "source": "/(api|threads|health|static)/(.*)",
      "destination": "main.py"
    },
    {
      "source": "/",
      "destination": "main.py"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
